digraph model_graph {
  // Dotfile by Django-Extensions graph_models
  // Created: 2026-04-06 18:02
  // Cli Options: accounts core api -g -o news_graph.dot

  fontname = "Roboto"
  fontsize = 8
  splines  = true
  rankdir = "TB"
  

  node [
    fontname = "Roboto"
    fontsize = 8
